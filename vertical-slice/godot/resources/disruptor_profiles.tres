; Disruptor profile manifest for #11 narrative wiring.
; Author notes:
; - `chaos_style`: pulse, drift, burst, or wave
;       pulse = consistent strength
;       drift  = weaker, creeping
;       burst  = stronger, sharp
;       wave   = oscillating strength
; - `base_chaos_rate` maps to `variant.intensity`
; - `chaos_variance` reserved for future jitter

[resource]

type="DisruptorProfile"
id="static_junkie"
display_name="Static Junkie"
description="Sharp, erratic pulses that spike the sensory meter quickly."
chaos_style="pulse"
base_chaos_rate=0.9
chaos_variance=0.1
color=Color(1.0, 0.3, 0.3)

[resource]

type="DisruptorProfile"
id="acoustic_bleed"
display_name="Acoustic Bleed"
description="A low, creeping pressure that wears down calm over time."
chaos_style="drift"
base_chaos_rate=0.45
chaos_variance=0.05
color=Color(0.4, 0.7, 1.0)

[resource]

type="DisruptorProfile"
id="overload_artist"
display_name="Overload Artist"
description="Unpredictiable bursts of chaos that feel like loud crowd noise."
chaos_style="burst"
base_chaos_rate=1.3
chaos_variance=0.35
color=Color(1.0, 0.8, 0.2)

[resource]

type="DisruptorProfile"
id="echo_weaver"
display_name="Echo Weaver"
description="Rhythmic, wave-like fluctuations that pull focus off baseline."
chaos_style="wave"
base_chaos_rate=0.7
chaos_variance=0.15
color=Color(0.5, 1.0, 0.6)
